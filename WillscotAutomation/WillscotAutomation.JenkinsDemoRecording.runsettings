<?xml version="1.0" encoding="utf-8"?>
<!--
  Jenkins Demo Recording runsettings
  Runs ONLY the @jenkins-demo scenario which records the live pipeline in a browser.

  Usage:
    cd WillscotAutomation
    dotnet test --no-build --configuration Release ^
      --settings WillscotAutomation.JenkinsDemoRecording.runsettings

  Before running:
    1. Ensure Jenkins is accessible at the BaseUrl in appsettings.json (default: http://localhost:8080)
    2. If Jenkins security is enabled, set Username and ApiToken in JenkinsDemoSettings
    3. The video is saved to bin\Release\net8.0\videos\TC-DEMO-01_*.webm and attached to Allure
-->
<RunSettings>

  <RunConfiguration>
    <MaxCpuCount>1</MaxCpuCount>
    <TargetFrameworkVersion>net8.0</TargetFrameworkVersion>
  </RunConfiguration>

  <NUnit>
    <NumberOfTestWorkers>1</NumberOfTestWorkers>
    <Where>cat == "jenkins-demo"</Where>
  </NUnit>

</RunSettings>
