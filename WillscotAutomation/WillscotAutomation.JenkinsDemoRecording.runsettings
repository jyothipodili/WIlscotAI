<?xml version="1.0" encoding="utf-8"?>
<RunSettings>

  <!--
    Runs ONLY the @jenkins-demo scenario.
    Usage: dotnet test /no-build /configuration Release
           /settings WillscotAutomation.JenkinsDemoRecording.runsettings
    Before running: set JenkinsDemoSettings in appsettings.json (BaseUrl, Username, ApiToken).
  -->

  <RunConfiguration>
    <MaxCpuCount>1</MaxCpuCount>
    <TargetFrameworkVersion>net8.0</TargetFrameworkVersion>
  </RunConfiguration>

  <NUnit>
    <NumberOfTestWorkers>1</NumberOfTestWorkers>
    <Where>cat == "jenkins-demo"</Where>
  </NUnit>

</RunSettings>
